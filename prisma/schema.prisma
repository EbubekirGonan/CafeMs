generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TableStatus {
  EMPTY
  OCCUPIED
}

enum OrderStatus {
  OPEN
  PAID
}

model User {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String   @unique
  passwordHash  String   @map("password_hash")
  name          String
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("users")
}

model Product {
  id        String      @id @default(uuid()) @db.Uuid
  name      String      @unique
  price     Decimal     @db.Decimal(10, 2)
  category  String?
  isActive  Boolean     @default(true) @map("is_active")
  createdAt DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime    @updatedAt @map("updated_at") @db.Timestamptz
  orderItems OrderItem[]

  @@map("products")
}

model Table {
  id        String      @id @default(uuid()) @db.Uuid
  number    Int         @unique
  capacity  Int?
  status    TableStatus @default(EMPTY)
  createdAt DateTime    @default(now()) @map("created_at") @db.Timestamptz
  orders    Order[]

  @@map("tables")
}

model Order {
  id            String         @id @default(uuid()) @db.Uuid
  tableId       String         @map("table_id") @db.Uuid
  status        OrderStatus    @default(OPEN)
  openedAt      DateTime       @default(now()) @map("opened_at") @db.Timestamptz
  closedAt      DateTime?      @map("closed_at") @db.Timestamptz
  totalAmount   Decimal        @default(0) @map("total_amount") @db.Decimal(10, 2)
  
  table         Table          @relation(fields: [tableId], references: [id])
  items         OrderItem[]
  revenueRecord RevenueRecord?

  @@index([tableId, status])
  @@map("orders")
}

model OrderItem {
  id        String   @id @default(uuid()) @db.Uuid
  orderId   String   @map("order_id") @db.Uuid
  productId String   @map("product_id") @db.Uuid
  quantity  Int
  unitPrice Decimal  @map("unit_price") @db.Decimal(10, 2) // Snapshot price
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  order     Order    @relation(fields: [orderId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

model Expense {
  id          String   @id @default(uuid()) @db.Uuid
  description String
  quantity    Decimal? @db.Decimal(10, 3)
  unit        String?
  unitPrice   Decimal? @map("unit_price") @db.Decimal(10, 2)
  totalAmount Decimal  @map("total_amount") @db.Decimal(10, 2)
  category    String
  expenseDate DateTime @default(now()) @map("expense_date") @db.Date
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@index([expenseDate])
  @@map("expenses")
}

model RevenueRecord {
  id          String   @id @default(uuid()) @db.Uuid
  orderId     String   @unique @map("order_id") @db.Uuid
  amount      Decimal  @db.Decimal(10, 2)
  revenueDate DateTime @map("revenue_date") @db.Date
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  order       Order    @relation(fields: [orderId], references: [id])

  @@index([revenueDate])
  @@map("revenue_records")
}